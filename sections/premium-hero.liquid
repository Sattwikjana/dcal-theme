<section class="sec noise pp-hero-sec" style="background:linear-gradient(135deg,#ECFEFF 0%,#F0F9FF 60%,#FAF5FF 100%);display:flex;align-items:flex-start;padding:48px 0 80px 0">
  <div class="blob b1"></div><div class="blob b2"></div><div class="blob b3"></div>
  <div class="container" style="position:relative;z-index:2">
    <div style="display:grid;grid-template-columns:1.1fr .9fr;gap:60px;align-items:center" class="hero-grid">
      <div>
        <span class="eyebrow" data-reveal>{{ section.settings.eyebrow }}</span>
        <h1 class="h-display" data-reveal data-reveal-delay="1" style="margin:24px 0 20px">
          {{ section.settings.heading }}
          <span class="grad-text">{{ section.settings.heading_accent }}</span>
        </h1>
        <p class="lead" data-reveal data-reveal-delay="2">{{ section.settings.subtext }}</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:32px" data-reveal data-reveal-delay="3">
          <a href="{{ section.settings.cta_link | default: '#demo-form' }}" class="btn btn-primary magnetic">{{ section.settings.cta_text }}</a>
          {% if section.settings.cta2_text != blank %}<a href="{{ section.settings.cta2_link | default: '#science' }}" class="btn btn-ghost magnetic">{{ section.settings.cta2_text }}</a>{% endif %}
        </div>
        <div style="display:flex;gap:40px;margin-top:48px;flex-wrap:wrap" data-reveal data-reveal-delay="4">
          <div><div class="stat"><span data-counter="50000">0</span>+</div><div style="color:#64748B;font-size:14px;font-weight:500">Happy Homes</div></div>
          <div><div class="stat"><span data-counter="99">0</span>%</div><div style="color:#64748B;font-size:14px;font-weight:500">Hardness Reduced</div></div>
          <div><div class="stat"><span data-counter="365">0</span></div><div style="color:#64748B;font-size:14px;font-weight:500">Days Protection</div></div>
        </div>
      </div>
      <div data-reveal data-reveal-delay="2" style="position:relative">
        <div class="glass tilt" style="padding:18px;transform-style:preserve-3d">
          {% if section.settings.hero_image != blank %}
            <div style="aspect-ratio:4/5;border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#ECFEFF,#F0F9FF)">
              <img src="{{ section.settings.hero_image | image_url: width: 900 }}"
                   width="900" height="1125" loading="lazy"
                   alt="{{ section.settings.heading | escape }}"
                   style="width:100%;height:100%;object-fit:cover;display:block;transition:transform .6s cubic-bezier(.2,.7,.2,1)">
            </div>
          {% else %}
            <div style="aspect-ratio:4/5;border-radius:18px;background:linear-gradient(135deg,#0EA5E9,#00C7B7);display:flex;align-items:center;justify-content:center;color:#fff;font-size:24px;font-weight:700">Upload Hero Image</div>
          {% endif %}
        </div>
        <div class="glass" style="position:absolute;left:-30px;bottom:30px;padding:16px 22px;display:flex;gap:12px;align-items:center;z-index:3" data-parallax=".05">
          <div style="width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,#22C55E,#0EA5E9);display:flex;align-items:center;justify-content:center;color:#fff">{% render 'icon', name: 'star', size: 20 %}</div>
          <div><div style="font-weight:700">4.8 / 5</div><div style="font-size:12px;color:#64748B">12,840+ reviews</div></div>
        </div>
        <div class="glass" style="position:absolute;right:-20px;top:30px;padding:14px 18px;z-index:3" data-parallax=".08">
          <div style="font-size:12px;color:#64748B">CERTIFIED BY</div>
          <div style="font-weight:700">NABL · ISO 9001</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media(max-width:900px){.hero-grid{grid-template-columns:1fr !important}}
  @media(max-width:900px){.pp-hero-sec{padding:32px 0 60px 0 !important}}
  .glass.tilt:hover img{transform:scale(1.04)}
</style>

{% schema %}
{
  "name":"Premium Hero",
  "settings":[
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"India's #1 Hard Water Defense"},
    {"type":"text","id":"heading","label":"Heading","default":"Say goodbye to"},
    {"type":"text","id":"heading_accent","label":"Heading accent","default":"hard water damage."},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"Protect your skin, hair, appliances and plumbing with a zero-maintenance, eco-friendly water softener engineered for Indian homes."},
    {"type":"text","id":"cta_text","label":"Primary CTA text","default":"Get Free Demo Kit"},
    {"type":"url","id":"cta_link","label":"Primary CTA link"},
    {"type":"text","id":"cta2_text","label":"Secondary CTA text","default":"Watch how it works"},
    {"type":"url","id":"cta2_link","label":"Secondary CTA link"},
    {"type":"image_picker","id":"hero_image","label":"Hero image"}
  ],
  "presets":[{"name":"Premium Hero"}]
}
{% endschema %}