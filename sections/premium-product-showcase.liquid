<section class="sec pp-showcase-sec">
  <div class="container">
    <div class="pp-showcase-head">
      <span class="eyebrow" data-reveal>{{ section.settings.eyebrow }}</span>
      <h2 class="h-section" data-reveal data-reveal-delay="1" style="margin:20px 0 16px">{{ section.settings.heading }}</h2>
      <p class="lead" data-reveal data-reveal-delay="2" style="margin:0 auto">{{ section.settings.subheading }}</p>
    </div>

    {%- assign block_count = section.blocks.size -%}
    {%- assign half = block_count | divided_by: 2 -%}
    {%- assign odd_blocks = block_count | modulo: 2 -%}
    {%- if block_count > 0 and odd_blocks != 0 -%}
      {%- assign half = half | plus: 1 -%}
    {%- endif -%}

    <div class="pp-showcase-grid">
      <div class="pp-showcase-col pp-showcase-col-left">
        {% for block in section.blocks %}{% if forloop.index0 < half %}
          {%- assign ic = block.settings.icon | default: 'shield-check' -%}
          <div class="pp-feat-card tilt" data-reveal data-reveal-delay="{% cycle 1,2,3 %}">
            <div class="pp-feat-icon">{% render 'icon', name: ic, size: 28 %}</div>
            <div class="pp-feat-body">
              <h3 class="pp-feat-title">{{ block.settings.title }}</h3>
              <p class="pp-feat-desc">{{ block.settings.description }}</p>
            </div>
          </div>
        {% endif %}{% endfor %}
      </div>

      <div class="pp-showcase-image-wrap" data-reveal data-reveal-delay="2">
        <div class="pp-showcase-radial"></div>
        <div class="glass tilt pp-showcase-card">
          {% if section.settings.product_image != blank %}
            <div class="pp-showcase-image">
              <img src="{{ section.settings.product_image | image_url: width: 900 }}"
                   width="900" height="900" loading="lazy"
                   alt="{{ section.settings.heading | escape }}">
            </div>
          {% else %}
            <div class="pp-showcase-image pp-showcase-placeholder">
              {% render 'icon', name: 'droplet', size: 80 %}
              <span>Upload product image</span>
            </div>
          {% endif %}
        </div>
        {% if section.settings.show_badge %}
        <div class="pp-showcase-badge">{{ section.settings.badge_text }}</div>
        {% endif %}
      </div>

      <div class="pp-showcase-col pp-showcase-col-right">
        {% for block in section.blocks %}{% if forloop.index0 >= half %}
          {%- assign ic = block.settings.icon | default: 'shield-check' -%}
          <div class="pp-feat-card tilt" data-reveal data-reveal-delay="{% cycle 1,2,3 %}">
            <div class="pp-feat-icon">{% render 'icon', name: ic, size: 28 %}</div>
            <div class="pp-feat-body">
              <h3 class="pp-feat-title">{{ block.settings.title }}</h3>
              <p class="pp-feat-desc">{{ block.settings.description }}</p>
            </div>
          </div>
        {% endif %}{% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  .pp-showcase-sec{background:linear-gradient(180deg,#ECF9FF 0%,#D6F2FA 100%);padding:100px 0}
  .pp-showcase-head{text-align:center;max-width:760px;margin:0 auto 64px}

  .pp-showcase-grid{display:grid;grid-template-columns:1fr 1.2fr 1fr;gap:36px;align-items:center}
  .pp-showcase-col{display:flex;flex-direction:column;gap:20px}

  .pp-feat-card{display:flex;gap:16px;align-items:flex-start;padding:20px;background:#fff;border:1px solid #E2E8F0;border-radius:20px;box-shadow:0 8px 24px -16px rgba(2,8,23,.15);transition:transform .35s ease,box-shadow .35s ease}
  .pp-feat-card:hover{transform:translateY(-4px);box-shadow:0 18px 36px -16px rgba(2,8,23,.22)}
  .pp-feat-icon{flex-shrink:0;display:inline-flex;align-items:center;justify-content:center;width:56px;height:56px;border-radius:50%;background:#ECF9FF;color:#00B4D8}
  .pp-feat-body{min-width:0}
  .pp-feat-title{font-size:16px;font-weight:700;color:#0B1220;margin:0 0 4px;letter-spacing:-.01em}
  .pp-feat-desc{font-size:13px;color:#475569;line-height:1.5;margin:0}

  .pp-showcase-image-wrap{position:relative;display:flex;align-items:center;justify-content:center;padding:20px 10px}
  .pp-showcase-radial{position:absolute;inset:0;background:radial-gradient(circle at center,#ECF9FF 0%,rgba(255,255,255,0) 70%);pointer-events:none}
  .pp-showcase-card{position:relative;width:100%;max-width:500px;padding:18px;background:#fff;border-radius:28px;box-shadow:0 30px 70px -25px rgba(2,8,23,.35);z-index:2}
  .pp-showcase-image{aspect-ratio:1;border-radius:20px;overflow:hidden;background:linear-gradient(135deg,#ECF9FF,#E3F4FB);display:flex;align-items:center;justify-content:center}
  .pp-showcase-image img{width:100%;height:100%;object-fit:contain;display:block;transition:transform .6s cubic-bezier(.2,.7,.2,1)}
  .pp-showcase-card:hover .pp-showcase-image img{transform:scale(1.04)}
  .pp-showcase-placeholder{flex-direction:column;gap:12px;color:#0077B6;font-weight:600}

  .pp-showcase-badge{position:absolute;top:8px;right:-8px;z-index:3;padding:12px 18px;border-radius:99px;background:linear-gradient(135deg,#48CAE4,#0077B6);color:#fff;font-weight:700;font-size:13px;letter-spacing:.02em;box-shadow:0 14px 30px -10px rgba(0,119,182,.55);transform:rotate(-8deg)}

  @media(max-width:1100px){
    .pp-showcase-grid{grid-template-columns:1fr 1.4fr 1fr;gap:24px}
  }
  @media(max-width:900px){
    .pp-showcase-sec{padding:60px 0}
    .pp-showcase-head{margin-bottom:40px}
    .pp-showcase-grid{grid-template-columns:1fr;gap:32px}
    .pp-showcase-col{display:grid;grid-template-columns:1fr 1fr;gap:16px}
    .pp-showcase-image-wrap{order:-1}
    .pp-showcase-card{max-width:360px}
    .pp-feat-card{padding:16px}
    .pp-feat-icon{width:48px;height:48px}
  }
  @media(max-width:520px){
    .pp-showcase-col{grid-template-columns:1fr}
    .pp-showcase-badge{font-size:11px;padding:10px 14px}
  }
</style>

{% schema %}
{
  "name":"Premium Product Showcase",
  "max_blocks":8,
  "settings":[
    {"type":"image_picker","id":"product_image","label":"Central product image"},
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"WHY CHOOSE D'CAL"},
    {"type":"text","id":"heading","label":"Heading","default":"The revolutionary hard water conditioner"},
    {"type":"textarea","id":"subheading","label":"Subheading","default":"One drop. Whole-home protection. Zero maintenance."},
    {"type":"header","content":"Floating badge"},
    {"type":"checkbox","id":"show_badge","label":"Show \"Try before you buy\" badge","default":true},
    {"type":"text","id":"badge_text","label":"Badge text","default":"Try before you buy"}
  ],
  "blocks":[{
    "type":"feature","name":"Feature callout",
    "settings":[
      {"type":"select","id":"icon","label":"Icon","default":"shield-check","options":[
        {"value":"zap-off","label":"No electricity"},
        {"value":"wrench","label":"No maintenance"},
        {"value":"dollar-sign","label":"Cost effective"},
        {"value":"droplets","label":"Water quality"},
        {"value":"shield-check","label":"Shield (no plumbing)"},
        {"value":"leaf","label":"Sustainable"},
        {"value":"zap","label":"Lightning"},
        {"value":"droplet","label":"Drop"},
        {"value":"check-circle","label":"Check circle"},
        {"value":"shield","label":"Shield"},
        {"value":"home","label":"Home"}
      ]},
      {"type":"text","id":"title","label":"Title","default":"Feature title"},
      {"type":"textarea","id":"description","label":"Description","default":"Short feature description."}
    ]
  }],
  "presets":[{"name":"Premium Product Showcase","blocks":[
    {"type":"feature","settings":{"icon":"zap-off","title":"No Electricity","description":"Works on water pressure alone, even during power cuts"}},
    {"type":"feature","settings":{"icon":"wrench","title":"No Maintenance","description":"Zero servicing, zero salt refills, zero chemicals"}},
    {"type":"feature","settings":{"icon":"dollar-sign","title":"Cost Effective","description":"One-time investment of ₹4,500 vs ₹50,000+ alternatives"}},
    {"type":"feature","settings":{"icon":"droplets","title":"Consistent Water Quality","description":"Naturally mineralised water — taste stays pure"}},
    {"type":"feature","settings":{"icon":"shield-check","title":"No Plumbing","description":"Drop in your tank, 15-minute install, no plumber"}},
    {"type":"feature","settings":{"icon":"leaf","title":"A Sustainable Solution","description":"No water wastage. No regeneration. No power drain."}}
  ]}]
}
{% endschema %}
