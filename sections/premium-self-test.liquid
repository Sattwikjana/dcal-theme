<section class="sec pp-test-sec">
  <div class="container">
    <div class="pp-test-head">
      <span class="eyebrow" data-reveal style="background:rgba(0,180,216,.15);color:#90E0EF">{{ section.settings.eyebrow }}</span>
      <h2 class="h-section" data-reveal data-reveal-delay="1" style="color:#fff;margin:20px 0 16px">{{ section.settings.heading }}</h2>
      <p class="lead" data-reveal data-reveal-delay="2" style="color:#94A3B8;margin:0 auto">{{ section.settings.subheading }}</p>
    </div>

    <div class="pp-test-steps">
      {% for block in section.blocks %}
        {% if block.type == 'step' %}
        <div class="pp-test-step" data-reveal data-reveal-delay="{% cycle 1,2,3 %}">
          <div class="pp-test-step-num">{{ block.settings.number }}</div>
          <h3 class="pp-test-step-title">{{ block.settings.title }}</h3>
          <p class="pp-test-step-body">{{ block.settings.text }}</p>
        </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="pp-test-compare-wrap" data-reveal>
      <h3 class="pp-test-compare-title">{{ section.settings.compare_heading }}</h3>

      {%- assign before_img = section.settings.before_image -%}
      {%- assign after_img = section.settings.after_image -%}

      {% if before_img != blank and after_img != blank %}
        <div class="compare pp-test-compare">
          <img src="{{ before_img | image_url: width: 1200 }}" width="1200" height="750" loading="lazy" alt="{{ section.settings.before_label | escape }}">
          <img class="after" src="{{ after_img | image_url: width: 1200 }}" width="1200" height="750" loading="lazy" alt="{{ section.settings.after_label | escape }}">
          <div class="handle"><div class="knob">{% render 'icon', name: 'move-horizontal', size: 20 %}</div></div>
        </div>
        <div class="pp-test-compare-labels">
          <span>{{ section.settings.before_label }}</span><span>{{ section.settings.after_label }}</span>
        </div>
      {% else %}
        <div class="pp-test-static">
          <div class="pp-test-static-card">
            {% if before_img != blank %}
              <img src="{{ before_img | image_url: width: 800 }}" width="800" height="800" loading="lazy" alt="{{ section.settings.before_label | escape }}">
            {% else %}
              <div class="pp-test-placeholder">{% render 'icon', name: 'droplet', size: 64 %}<span>Before image</span></div>
            {% endif %}
            <div class="pp-test-static-label">{{ section.settings.before_label }}</div>
          </div>
          <div class="pp-test-static-card">
            {% if after_img != blank %}
              <img src="{{ after_img | image_url: width: 800 }}" width="800" height="800" loading="lazy" alt="{{ section.settings.after_label | escape }}">
            {% else %}
              <div class="pp-test-placeholder">{% render 'icon', name: 'droplet', size: 64 %}<span>After image</span></div>
            {% endif %}
            <div class="pp-test-static-label pp-test-static-label-pos">{{ section.settings.after_label }}</div>
          </div>
        </div>
      {% endif %}
    </div>

    {% if section.settings.guarantee_text != blank %}
    <div class="pp-test-guarantee" data-reveal>
      <span class="pp-test-guarantee-icon">{% render 'icon', name: 'check-circle', size: 18 %}</span>
      {{ section.settings.guarantee_text }}
    </div>
    {% endif %}
  </div>
</section>

<style>
  .pp-test-sec{background:linear-gradient(135deg,#023E8A 0%,#012A4A 100%);color:#fff;padding:100px 0}
  .pp-test-head{text-align:center;max-width:760px;margin:0 auto 60px}

  .pp-test-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:72px}
  .pp-test-step{padding:32px 28px;border-radius:24px;background:linear-gradient(160deg,rgba(255,255,255,.06),rgba(255,255,255,.02));border:1px solid rgba(255,255,255,.08);position:relative;overflow:hidden}
  .pp-test-step-num{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:56px;line-height:1;background:linear-gradient(135deg,#00B4D8,#0077B6);-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:14px;letter-spacing:-.04em}
  .pp-test-step-title{font-size:20px;font-weight:700;color:#fff;margin:0 0 10px;letter-spacing:-.01em}
  .pp-test-step-body{font-size:14px;color:#CBD5E1;line-height:1.6;margin:0}

  .pp-test-compare-wrap{max-width:1000px;margin:0 auto}
  .pp-test-compare-title{text-align:center;font-size:clamp(20px,2.4vw,28px);font-weight:700;color:#fff;margin:0 0 28px;letter-spacing:-.02em}
  .pp-test-compare-labels{display:flex;justify-content:space-between;margin-top:14px;color:#94A3B8;font-size:13px;font-weight:600;letter-spacing:.05em}

  .pp-test-static{display:grid;grid-template-columns:1fr 1fr;gap:20px}
  .pp-test-static-card{position:relative;border-radius:20px;overflow:hidden;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);aspect-ratio:1}
  .pp-test-static-card img{width:100%;height:100%;object-fit:cover;display:block}
  .pp-test-static-label{position:absolute;left:16px;bottom:16px;padding:8px 14px;border-radius:99px;background:rgba(11,18,32,.85);backdrop-filter:blur(10px);font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#fff}
  .pp-test-static-label-pos{background:linear-gradient(135deg,#00B4D8,#0077B6)}
  .pp-test-placeholder{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;color:#90E0EF;font-weight:600}

  .pp-test-guarantee{display:inline-flex;align-items:center;gap:10px;margin:48px auto 0;padding:16px 28px;border-radius:99px;background:linear-gradient(135deg,#00B4D8,#0077B6);color:#fff;font-size:15px;font-weight:600;box-shadow:0 18px 40px -12px rgba(0,180,216,.55);left:50%;position:relative;transform:translateX(-50%);text-align:center}
  .pp-test-guarantee-icon{display:inline-flex;align-items:center}

  @media(max-width:900px){
    .pp-test-sec{padding:60px 0}
    .pp-test-steps{grid-template-columns:1fr;margin-bottom:48px}
    .pp-test-step{padding:24px 22px}
    .pp-test-step-num{font-size:44px}
  }
  @media(max-width:520px){
    .pp-test-static{grid-template-columns:1fr}
  }
</style>

{% schema %}
{
  "name":"Premium Self Test",
  "max_blocks":3,
  "settings":[
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"TRY BEFORE YOU BUY"},
    {"type":"text","id":"heading","label":"Heading (HTML allowed)","default":"See the proof <span class='grad-text'>in 10 minutes</span>"},
    {"type":"textarea","id":"subheading","label":"Subheading","default":"Don't trust us — trust your own eyes. Run this simple test at home."},
    {"type":"header","content":"Comparison images"},
    {"type":"text","id":"compare_heading","label":"Comparison heading","default":"See the visual difference yourself"},
    {"type":"image_picker","id":"before_image","label":"Before image (ordinary bore water)"},
    {"type":"image_picker","id":"after_image","label":"After image (D'Cal treated)"},
    {"type":"text","id":"before_label","label":"Before label","default":"Ordinary Bore Water"},
    {"type":"text","id":"after_label","label":"After label","default":"D'Cal Treated Water"},
    {"type":"header","content":"Guarantee chip"},
    {"type":"text","id":"guarantee_text","label":"Guarantee text","default":"6-Month Free Replacement Warranty"}
  ],
  "blocks":[{
    "type":"step","name":"Test step",
    "settings":[
      {"type":"text","id":"number","label":"Number badge","default":"01"},
      {"type":"text","id":"title","label":"Title","default":"Step title"},
      {"type":"textarea","id":"text","label":"Body","default":"Describe the step."}
    ]
  }],
  "presets":[{"name":"Premium Self Test","blocks":[
    {"type":"step","settings":{"number":"01","title":"Use D'Cal for 1 day","text":"Install the cartridge in your overhead tank and let it work for 24 hours."}},
    {"type":"step","settings":{"number":"02","title":"Collect 2 water samples","text":"Take 1 litre of your regular borewell water and 1 litre of D'Cal-treated water in separate steel utensils."}},
    {"type":"step","settings":{"number":"03","title":"Heat for 10-15 minutes","text":"Heat both samples for 10-15 minutes. The difference will be visible to your naked eye."}}
  ]}]
}
{% endschema %}
