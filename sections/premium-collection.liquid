<section class="sec" style="background:linear-gradient(180deg,#fff,#F0FDFA);padding:64px 0;min-height:60vh">
  <div class="container">
    <div style="margin-bottom:28px">
      <span class="eyebrow" data-reveal>COLLECTION</span>
      <h1 class="h-section" data-reveal data-reveal-delay="1" style="margin:12px 0 0">{{ collection.title }}</h1>
      {% if collection.description != blank %}<p class="lead" data-reveal data-reveal-delay="2" style="margin-top:12px">{{ collection.description | strip_html | truncate: 200 }}</p>{% endif %}
    </div>

    <div class="pp-col-grid" style="display:grid;grid-template-columns:260px 1fr;gap:32px;align-items:start">
      <aside class="pp-col-filters" style="position:sticky;top:120px">
        <form method="get">
          {% if collection.sort_by != blank %}<input type="hidden" name="sort_by" value="{{ collection.sort_by }}">{% endif %}
          {% for filter in collection.filters %}
            <div class="glass" style="background:#fff;padding:18px;border-radius:18px;margin-bottom:14px">
              <div style="font-weight:700;font-size:14px;margin-bottom:12px">{{ filter.label }}</div>
              {% case filter.type %}
              {% when 'list', 'boolean' %}
                <div style="display:grid;gap:8px">
                  {% for value in filter.values %}
                    <label style="display:flex;align-items:center;gap:8px;font-size:14px;color:#475569;cursor:pointer">
                      <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" data-autosubmit {% if value.active %}checked{% endif %}>
                      <span>{{ value.label }} <span style="color:#94A3B8">({{ value.count }})</span></span>
                    </label>
                  {% endfor %}
                </div>
              {% when 'price_range' %}
                <div style="display:flex;gap:8px;align-items:center">
                  <input type="number" name="{{ filter.min_value.param_name }}" placeholder="Min" value="{{ filter.min_value.value }}" aria-label="Minimum price" style="width:50%;padding:8px;border:1px solid #E2E8F0;border-radius:8px">
                  <input type="number" name="{{ filter.max_value.param_name }}" placeholder="Max" value="{{ filter.max_value.value }}" aria-label="Maximum price" style="width:50%;padding:8px;border:1px solid #E2E8F0;border-radius:8px">
                </div>
                <button type="submit" class="btn btn-ghost" style="margin-top:10px;width:100%;justify-content:center;padding:8px">Apply</button>
              {% endcase %}
            </div>
          {% else %}
            <div style="font-size:13px;color:#94A3B8">No filters configured for this collection.</div>
          {% endfor %}
        </form>
      </aside>

      <div>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:12px">
          <div style="font-size:14px;color:#64748B">{{ collection.products_count }} products</div>
          <form method="get">
            {%- assign sort = collection.sort_by | default: collection.default_sort_by -%}
            <label for="pp-sort" style="font-size:13px;color:#64748B;margin-right:8px">Sort</label>
            <select id="pp-sort" name="sort_by" data-autosubmit aria-label="Sort products">
              {% for option in collection.sort_options %}
                <option value="{{ option.value }}" {% if option.value == sort %}selected{% endif %}>{{ option.name }}</option>
              {% endfor %}
            </select>
          </form>
        </div>

        {% paginate collection.products by 12 %}
          <div class="grid grid-3">
            {% for product in collection.products %}
              <a href="{{ product.url }}" class="tilt" style="text-decoration:none;color:inherit">
                <div style="padding:18px;background:#fff;border-radius:22px;border:1px solid rgba(226,232,240,.7);box-shadow:0 12px 40px -16px rgba(2,8,23,.12);height:100%">
                  <div style="aspect-ratio:1;border-radius:16px;overflow:hidden;background:linear-gradient(135deg,#ECFEFF,#F0F9FF);margin-bottom:14px;display:flex;align-items:center;justify-content:center">
                    {% if product.featured_image %}
                      <img src="{{ product.featured_image | image_url: width: 600 }}" width="600" height="600" loading="lazy" alt="{{ product.title | escape }}" style="width:100%;height:100%;object-fit:contain">
                    {% else %}<div style="color:#94A3B8;display:flex;align-items:center;justify-content:center">{% render 'icon', name: 'package', size: 52 %}</div>{% endif %}
                  </div>
                  <div style="font-size:12px;font-weight:700;color:#0F766E;text-transform:uppercase;letter-spacing:.08em">{{ product.type | default: 'Premium' }}</div>
                  <h3 style="font-size:18px;font-weight:700;margin:6px 0 8px;color:#0B1220">{{ product.title }}</h3>
                  <div style="display:flex;align-items:center;gap:8px">
                    <span style="font-size:18px;font-weight:800">{{ product.price | money }}</span>
                    {% if product.compare_at_price > product.price %}<span style="font-size:13px;color:#94A3B8;text-decoration:line-through">{{ product.compare_at_price | money }}</span>{% endif %}
                  </div>
                </div>
              </a>
            {% else %}
              <p class="lead">No products found.</p>
            {% endfor %}
          </div>
          {% if paginate.pages > 1 %}
            <div style="display:flex;gap:8px;justify-content:center;margin-top:40px">
              {% if paginate.previous %}<a href="{{ paginate.previous.url }}" class="btn btn-ghost">{% render 'icon', name: 'arrow-left', size: 16 %} Prev</a>{% endif %}
              {% if paginate.next %}<a href="{{ paginate.next.url }}" class="btn btn-ghost">Next {% render 'icon', name: 'arrow-right', size: 16 %}</a>{% endif %}
            </div>
          {% endif %}
        {% endpaginate %}
      </div>
    </div>
  </div>
</section>

<style>
  @media(max-width:900px){.pp-col-grid{grid-template-columns:1fr !important}.pp-col-filters{position:static !important}}
</style>

<script>
  (function(){
    document.querySelectorAll('[data-autosubmit]').forEach(function(el){
      el.addEventListener('change',function(){ if(el.form)el.form.submit(); });
    });
  })();
</script>

{% schema %}
{
  "name": "Premium Collection",
  "settings": []
}
{% endschema %}
