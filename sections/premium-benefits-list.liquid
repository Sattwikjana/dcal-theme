<section class="sec pp-benefits-sec">
  <div class="container">
    <div class="pp-benefits-head">
      <span class="eyebrow" data-reveal>{{ section.settings.eyebrow }}</span>
      <h2 class="h-section" data-reveal data-reveal-delay="1" style="margin:20px 0 0">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="lead" data-reveal data-reveal-delay="2" style="margin:20px auto 0">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="pp-benefits-grid">
      {% for block in section.blocks %}
      <div class="pp-benefit-card tilt" data-reveal data-reveal-delay="{% cycle 1,2,3,4 %}">
        <span class="pp-benefit-badge">{{ section.settings.badge_text | default: 'NO' }}</span>
        <span class="pp-benefit-check">{% render 'icon', name: 'check-circle', size: 22 %}</span>
        <h3 class="pp-benefit-title">{{ block.settings.title }}</h3>
        {% if block.settings.subtext != blank %}
          <p class="pp-benefit-subtext">{{ block.settings.subtext }}</p>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .pp-benefits-sec{background:linear-gradient(180deg,#ECFEFF 0%,#fff 100%);padding:100px 0}
  .pp-benefits-head{text-align:center;max-width:720px;margin:0 auto 56px}

  .pp-benefits-grid{display:flex;flex-wrap:wrap;justify-content:center;gap:20px;max-width:1140px;margin:0 auto}
  .pp-benefit-card{position:relative;width:250px;padding:28px 24px 24px;background:#fff;border:1px solid #E2E8F0;border-radius:20px;box-shadow:0 10px 28px -18px rgba(2,8,23,.18);transition:transform .35s ease,box-shadow .35s ease}
  .pp-benefit-card:hover{transform:translateY(-4px);box-shadow:0 22px 44px -18px rgba(2,8,23,.25)}

  .pp-benefit-badge{position:absolute;top:-12px;left:20px;padding:6px 14px;border-radius:99px;background:linear-gradient(135deg,#EF4444,#DC2626);color:#fff;font-size:12px;font-weight:800;letter-spacing:.08em;box-shadow:0 10px 22px -8px rgba(220,38,38,.55)}
  .pp-benefit-check{position:absolute;top:18px;right:18px;display:inline-flex;color:#00C7B7}

  .pp-benefit-title{margin:18px 0 0;font-size:18px;font-weight:700;color:#0B1220;letter-spacing:-.01em}
  .pp-benefit-subtext{margin:8px 0 0;font-size:13px;color:#64748B;line-height:1.55}

  @media(max-width:900px){
    .pp-benefits-sec{padding:60px 0}
    .pp-benefit-card{width:calc(50% - 10px);min-width:0}
  }
  @media(max-width:520px){
    .pp-benefit-card{width:100%}
  }
</style>

{% schema %}
{
  "name":"Premium Benefits List",
  "max_blocks":12,
  "settings":[
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"WHAT D'CAL DOESN'T NEED"},
    {"type":"text","id":"heading","label":"Heading (HTML allowed)","default":"Seven things you'll <span class='grad-text'>never deal with</span>"},
    {"type":"textarea","id":"subheading","label":"Subheading"},
    {"type":"text","id":"badge_text","label":"Badge text on each card","default":"NO"}
  ],
  "blocks":[{
    "type":"benefit","name":"Benefit card",
    "settings":[
      {"type":"text","id":"title","label":"Title","default":"Benefit title"},
      {"type":"text","id":"subtext","label":"Optional subtext"}
    ]
  }],
  "presets":[{"name":"Premium Benefits List","blocks":[
    {"type":"benefit","settings":{"title":"High Cost"}},
    {"type":"benefit","settings":{"title":"Maintenance"}},
    {"type":"benefit","settings":{"title":"Regeneration"}},
    {"type":"benefit","settings":{"title":"Plumbing Required"}},
    {"type":"benefit","settings":{"title":"Water Wastage"}},
    {"type":"benefit","settings":{"title":"Electricity Required"}},
    {"type":"benefit","settings":{"title":"Manpower Required"}}
  ]}]
}
{% endschema %}
