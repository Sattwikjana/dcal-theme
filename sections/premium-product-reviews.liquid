    {"type":"review","settings":{"rating":5,"verified":true,"title":"Glassware stopped getting cloudy","body":"We host dinner parties often. Our glassware always looked cloudy after dishwasher. After D'Cal — crystal clear. Embarrassing problem solved.","name":"Arjun Kapoor","location":"Gurugram · Google Review"}}
  ]}]
}
{% endschema %}
