    {"type":"review","settings":{"rating":4,"verified":true,"title":"Eczema symptoms much better","body":"My daughter has eczema. Within 2 months of installing D'Cal, her flare-ups reduced significantly. Shipping took 7 days, dropping 1 star for that.","name":"Ananya Singh","location":"Kolkata · Amazon Verified"}},
    {"type":"review","settings":{"rating":5,"verified":true,"title":"Works on heavy borewell water","body":"Our borewell water has TDS of around 950. Most softeners give up. D'Cal handles it. Bathroom is finally usable.","name":"Manoj Patel","location":"Ahmedabad · Verified Buyer"}},
