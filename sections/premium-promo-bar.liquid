{%- liquid
  assign msg = section.settings.message | default: 'Free shipping on orders over ₹2,000 · Use code DCAL10 at checkout'
  assign promo_id = msg | handleize
  assign code = section.settings.highlight_code | strip
  assign msg_html = msg
  if code != blank
    capture chip
      echo '<span class="promo-code">'
      echo code
      echo '</span>'
    endcapture
    assign msg_html = msg | replace: code, chip
  endif
-%}
<div id="pp-promo-bar" data-promo-key="dcal_promo_dismissed_v1_{{ promo_id }}" data-dismissible="{{ section.settings.dismissible }}" style="background:linear-gradient(90deg,#023E8A 0%,#0077B6 50%,#023E8A 100%);color:#fff;display:none;position:relative">
  <div class="pp-promo-inner" style="max-width:1240px;margin:0 auto;padding:0 48px;display:flex;align-items:center;justify-content:center;gap:8px;text-align:center">
    <span style="color:#90E0EF;display:inline-flex;flex-shrink:0">{% render 'icon', name: 'sparkles', size: 16 %}</span>
    {% if section.settings.link != blank %}
      <a class="pp-promo-msg" href="{{ section.settings.link }}" style="color:#fff;text-decoration:none">{{ msg_html }}</a>
    {% else %}
      <span class="pp-promo-msg">{{ msg_html }}</span>
    {% endif %}
    {% if section.settings.dismissible %}
      <button type="button" id="pp-promo-close" aria-label="Dismiss announcement">{% render 'icon', name: 'x', size: 18 %}</button>
    {% endif %}
  </div>
</div>

<style>
  #pp-promo-bar .pp-promo-inner{height:44px}
  #pp-promo-bar .pp-promo-msg{font-size:13px;font-weight:500;letter-spacing:.01em;color:#fff}
  #pp-promo-bar .promo-code{background:rgba(144,224,239,.15);color:#90E0EF;padding:2px 8px;border-radius:4px;font-weight:600;letter-spacing:.5px;margin:0 4px}
  #pp-promo-close{position:absolute;right:16px;top:50%;transform:translateY(-50%);display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;padding:10px;color:rgba(255,255,255,.5);transition:color .2s,transform .2s}
  #pp-promo-close:hover{color:#fff;transform:translateY(-50%) scale(1.1)}
  @media(max-width:600px){
    #pp-promo-bar .pp-promo-inner{height:40px;padding:0 40px}
    #pp-promo-bar .pp-promo-msg{font-size:11px}
  }
</style>

<script>
(function(){
  var bar=document.getElementById('pp-promo-bar'); if(!bar)return;
  var key=bar.dataset.promoKey;
  if(bar.dataset.dismissible==='true'){
    try{ if(localStorage.getItem(key)==='1'){ bar.remove(); return; } }catch(e){}
  }
  bar.style.display='block';
  var close=document.getElementById('pp-promo-close');
  if(close)close.addEventListener('click',function(){
    bar.style.display='none';
    try{ localStorage.setItem(key,'1'); }catch(e){}
  });
})();
</script>

{% schema %}
{
  "name": "Premium Promo Bar",
  "settings": [
    {"type": "text", "id": "message", "label": "Message", "default": "Free shipping on orders over ₹2,000 · Use code DCAL10 at checkout", "info": "Changing this text re-shows the bar to everyone who dismissed the previous message."},
    {"type": "text", "id": "highlight_code", "label": "Highlight code", "info": "If this exact text appears in the message (e.g. DCAL10), it's shown as a highlighted chip."},
    {"type": "url", "id": "link", "label": "Link (optional)"},
    {"type": "checkbox", "id": "dismissible", "label": "Allow visitors to dismiss", "default": true}
  ],
  "presets": [{"name": "Premium Promo Bar", "settings": {"highlight_code": "DCAL10"}}]
}
{% endschema %}
