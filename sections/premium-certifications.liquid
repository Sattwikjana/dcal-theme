<section class="sec pp-certs-sec">
  <div class="container">
    <div class="pp-certs-head">
      <span class="eyebrow" data-reveal>{{ section.settings.eyebrow }}</span>
      <h2 class="h-section" data-reveal data-reveal-delay="1" style="margin:20px 0 0">{{ section.settings.heading }}</h2>
    </div>

    <div class="pp-certs-row">
      {% for block in section.blocks %}
        {%- assign ic = block.settings.icon | default: 'shield-check' -%}
        {%- assign use_flag = false -%}
        {%- if block.settings.use_tricolor -%}{%- assign use_flag = true -%}{%- endif -%}
        <div class="pp-cert-card glass" data-reveal data-reveal-delay="{% cycle 1,2,3,4 %}">
          <div class="pp-cert-icon">
            {% if use_flag %}
              <span class="pp-cert-tricolor" aria-hidden="true">
                <span class="pp-cert-stripe pp-cert-saffron"></span>
                <span class="pp-cert-stripe pp-cert-white"></span>
                <span class="pp-cert-stripe pp-cert-green"></span>
              </span>
            {% else %}
              {% render 'icon', name: ic, size: 32 %}
            {% endif %}
          </div>
          {% if block.settings.title != blank %}
            <h3 class="pp-cert-title">{{ block.settings.title }}</h3>
          {% endif %}
          <p class="pp-cert-text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .pp-certs-sec{background:linear-gradient(180deg,#ADE8F4 0%,#90E0EF 100%);padding:80px 0}
  .pp-certs-head{text-align:center;max-width:760px;margin:0 auto 48px}

  .pp-certs-row{display:flex;flex-wrap:wrap;justify-content:center;gap:18px;max-width:1140px;margin:0 auto}
  .pp-cert-card{width:200px;padding:24px 20px;background:rgba(255,255,255,.9);border:1px solid #E2E8F0;border-radius:20px;text-align:center;filter:grayscale(60%);opacity:.85;transition:filter .35s ease,opacity .35s ease,transform .35s ease,box-shadow .35s ease;box-shadow:0 12px 28px -20px rgba(2,8,23,.18)}
  .pp-cert-card:hover{filter:grayscale(0);opacity:1;transform:translateY(-4px);box-shadow:0 22px 44px -20px rgba(2,8,23,.22)}

  .pp-cert-icon{display:inline-flex;align-items:center;justify-content:center;width:56px;height:56px;border-radius:50%;background:#ECF9FF;color:#0077B6;margin-bottom:14px}
  .pp-cert-title{margin:0 0 4px;font-size:15px;font-weight:700;color:#0B1220;letter-spacing:-.01em}
  .pp-cert-text{margin:0;font-size:13px;color:#475569;line-height:1.5}

  .pp-cert-tricolor{display:inline-flex;flex-direction:column;width:36px;height:24px;border-radius:3px;overflow:hidden;border:1px solid rgba(0,0,0,.08)}
  .pp-cert-stripe{display:block;height:33.33%;width:100%}
  .pp-cert-saffron{background:#FF9933}
  .pp-cert-white{background:#fff;position:relative}
  .pp-cert-white::after{content:"";position:absolute;left:50%;top:50%;width:6px;height:6px;border-radius:50%;border:1px solid #000080;transform:translate(-50%,-50%)}
  .pp-cert-green{background:#138808}

  @media(max-width:900px){
    .pp-certs-sec{padding:60px 0}
    .pp-cert-card{width:calc(50% - 9px);min-width:0}
  }
  @media(max-width:520px){
    .pp-cert-card{width:100%}
  }
</style>

{% schema %}
{
  "name":"Premium Certifications",
  "max_blocks":8,
  "settings":[
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"CERTIFIED & TRUSTED"},
    {"type":"text","id":"heading","label":"Heading","default":"Lab-tested. Government-certified. Made in India."}
  ],
  "blocks":[{
    "type":"cert","name":"Certification badge",
    "settings":[
      {"type":"select","id":"icon","label":"Icon","default":"shield-check","options":[
        {"value":"shield-check","label":"Shield check"},
        {"value":"award","label":"Award"},
        {"value":"leaf","label":"Leaf (food grade)"},
        {"value":"lightbulb","label":"Lightbulb (innovation)"},
        {"value":"flag","label":"Flag"},
        {"value":"check-circle","label":"Check circle"},
        {"value":"star","label":"Star"}
      ]},
      {"type":"checkbox","id":"use_tricolor","label":"Use tricolor strip instead of icon (for \"Made in India\")","default":false},
      {"type":"text","id":"title","label":"Title (optional)"},
      {"type":"text","id":"text","label":"Text","default":"Certification name"}
    ]
  }],
  "presets":[{"name":"Premium Certifications","blocks":[
    {"type":"cert","settings":{"icon":"shield-check","text":"ISO 9001 Quality Management"}},
    {"type":"cert","settings":{"icon":"award","text":"IP India #317385-001"}},
    {"type":"cert","settings":{"icon":"leaf","text":"Food Grade Certified"}},
    {"type":"cert","settings":{"icon":"lightbulb","text":"Awarded by Telangana State Innovation Cell"}},
    {"type":"cert","settings":{"use_tricolor":true,"text":"Proudly Made in India"}}
  ]}]
}
{% endschema %}
